---
pagination:
  data: collections.events
  size: 1
  alias: event
permalink: "/dogodki/{{ event.data.slug }}/"
eleventyComputed:
  title: "{{ event.data.title }} — Galaxy Sport"
---
{% include "head.njk" %}
<body class="event-page">

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="i-cal" viewBox="0 0 16 16">
      <rect x="2" y="3" width="12" height="11" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <path d="M5 1.5v3M11 1.5v3M2 7h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </symbol>
    <symbol id="i-pin" viewBox="0 0 16 16">
      <path d="M8 1.5c-2.8 0-5 2.1-5 4.7C3 9.5 8 14.5 8 14.5s5-5 5-8.3c0-2.6-2.2-4.7-5-4.7z" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="8" cy="6" r="1.6" fill="none" stroke="currentColor" stroke-width="1.4"/>
    </symbol>
    <symbol id="i-people" viewBox="0 0 16 16">
      <circle cx="6" cy="5" r="2.2" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="11.5" cy="6" r="1.7" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <path d="M2 13c0-2.2 1.8-3.5 4-3.5s4 1.3 4 3.5M10 13c0-1.6 1.2-2.7 3-2.7" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </symbol>
    <symbol id="i-bar" viewBox="0 0 16 16">
      <path d="M2 13 L6 9 L10 11 L14 5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="14" cy="5" r="1.4" fill="currentColor"/>
    </symbol>
    <symbol id="i-check" viewBox="0 0 16 16">
      <path d="M3 8 L7 12 L13 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>
    <symbol id="i-x" viewBox="0 0 16 16">
      <path d="M4 4 L12 12 M12 4 L4 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </symbol>
    <symbol id="i-pack" viewBox="0 0 16 16">
      <path d="M5 6 L5 4 Q5 2.5 6.5 2.5 L9.5 2.5 Q11 2.5 11 4 L11 6" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <rect x="3" y="6" width="10" height="8" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.4"/>
      <path d="M6 9 L10 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </symbol>
    <symbol id="i-arrow-left" viewBox="0 0 16 16">
      <path d="M9 3 L4 8 L9 13 M4 8 L13 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>
  </defs>
</svg>

<header id="header">
  <div class="container nav">
    <a href="/" class="logo" aria-label="Galaxy Sport">
      <img src="/images/logo-dark.png" alt="Galaxy Sport">
    </a>
    <ul class="nav-links">
      <li><a href="/#events">Dogodki</a></li>
      <li><a href="/#shop">Servis</a></li>
      <li><a href="/#about">O nas</a></li>
      <li><a href="/#gallery">Galerija</a></li>
      <li><a href="/#faq">FAQ</a></li>
    </ul>
    <a href="#registration" class="btn btn-primary">Prijavi se</a>
  </div>
</header>

<section class="event-hero">
  {% if event.data.image %}
  <div class="event-hero-bg" style="background-image: url('{{ event.data.image }}');"></div>
  <div class="event-hero-overlay"></div>
  {% else %}
  <div class="event-hero-bg event-hero-bg-default"></div>
  {% endif %}

  <div class="container event-hero-content">
    <a href="/#events" class="back-link"><svg><use href="#i-arrow-left"/></svg> Vsi dogodki</a>
    <div class="event-tags">
      <span class="event-tag-large{% if event.data.tag_hot %} hot{% endif %}">{{ event.data.tag }}</span>
    </div>
    <h1 class="event-title">{{ event.data.title }}</h1>
    <div class="event-meta-row">
      <span><svg><use href="#i-cal"/></svg> {{ event.data.date_label }}</span>
      <span><svg><use href="#i-pin"/></svg> {{ event.data.location }}</span>
      <span><svg><use href="#i-people"/></svg> {{ event.data.group_size or event.data.audience }}</span>
      {% if event.data.difficulty %}<span><svg><use href="#i-bar"/></svg> {{ event.data.difficulty }}</span>{% endif %}
    </div>
  </div>
</section>

<section class="event-body">
  <div class="container event-grid">
    <main class="event-main">

      <div class="event-description">{{ event.templateContent | safe }}</div>

      {% if event.data.event_gallery and event.data.event_gallery.length %}
      <section class="event-gallery-section">
        <div class="event-gallery-grid event-gallery-count-{{ event.data.event_gallery.length }}">
          {% for photo in event.data.event_gallery %}
          <button type="button" class="event-gallery-item" data-photo-index="{{ loop.index0 }}" aria-label="Odpri fotografijo {{ loop.index }}">
            <img src="{{ photo }}" alt="{{ event.data.title }} — fotografija {{ loop.index }}" loading="lazy">
          </button>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if event.data.itinerary and event.data.itinerary.length %}
      <section class="event-section">
        <h2 class="event-section-title">Program po dnevih</h2>
        <ol class="itinerary">
          {% for day in event.data.itinerary %}
          <li class="itinerary-day">
            <div class="itinerary-day-label">{{ day.day }}</div>
            <div class="itinerary-day-body">
              <h3 class="itinerary-day-title">{{ day.title }}</h3>
              <p>{{ day.content }}</p>
            </div>
          </li>
          {% endfor %}
        </ol>
      </section>
      {% endif %}

      <div class="event-two-col">
        {% if event.data.included and event.data.included.length %}
        <section class="event-section">
          <h2 class="event-section-title">Vključeno v ceno</h2>
          <ul class="check-list">
            {% for item in event.data.included %}
            <li><svg class="check-icon"><use href="#i-check"/></svg>{{ item }}</li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        {% if event.data.not_included and event.data.not_included.length %}
        <section class="event-section">
          <h2 class="event-section-title">Ni vključeno</h2>
          <ul class="x-list">
            {% for item in event.data.not_included %}
            <li><svg class="x-icon"><use href="#i-x"/></svg>{{ item }}</li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}
      </div>

      {% if event.data.to_bring and event.data.to_bring.length %}
      <section class="event-section">
        <h2 class="event-section-title">Kaj prinesi s sabo</h2>
        <ul class="bring-list">
          {% for item in event.data.to_bring %}
          <li><svg class="pack-icon"><use href="#i-pack"/></svg>{{ item }}</li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

    </main>

    <aside class="event-sidebar">
      <div class="event-booking-card" id="registration">
        <div class="event-price-block">
          <div class="event-price-num-large">{{ event.data.price_num }}</div>
          <div class="event-price-label-large">{{ event.data.price_label }}</div>
        </div>

        <div class="event-quick-info">
          <div class="quick-info-row">
            <span class="quick-info-label">Datum</span>
            <span class="quick-info-value">{{ event.data.date_label }}</span>
          </div>
          <div class="quick-info-row">
            <span class="quick-info-label">Lokacija</span>
            <span class="quick-info-value">{{ event.data.location }}</span>
          </div>
          <div class="quick-info-row">
            <span class="quick-info-label">Skupina</span>
            <span class="quick-info-value">{{ event.data.group_size or event.data.audience }}</span>
          </div>
          {% if event.data.instructor %}
          <div class="quick-info-row">
            <span class="quick-info-label">Vodi</span>
            <span class="quick-info-value">{{ event.data.instructor }}</span>
          </div>
          {% endif %}
        </div>

        <button type="button" class="btn btn-primary btn-lg btn-block btn-arrow" id="openFormBtn">
          {% if event.data.payment_url %}Prijava in plačilo{% else %}Prijavi se{% endif %}
        </button>

        <p class="event-reg-note">{{ event.data.registration_note }}</p>

        <div class="event-payment-info">
          <strong>Način plačila:</strong>
          {% if event.data.payment_url %}
          Po izpolnitvi prijavnice te preusmerimo na varno SumUp plačilno stran.
          {% else %}
          Po prijavi vam pošljemo podatke za nakazilo. Mesto v skupini je rezervirano po potrjenem plačilu.
          {% endif %}
        </div>
      </div>
    </aside>
  </div>
</section>

<!-- Registration form section -->
<section class="event-form-section" id="registrationForm">
  <div class="container">
    <div class="event-form-wrap">
      <h2 class="event-form-title">Prijava na dogodek</h2>
      <p class="event-form-sub">{{ event.data.title }} — {{ event.data.date_label }}</p>

      <form name="event-registration"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/hvala/"
            class="event-form"
            id="eventForm"
            data-payment-url="{{ event.data.payment_url }}">
        <input type="hidden" name="form-name" value="event-registration">
        <p class="hp-field"><label>Ne izpolnjuj: <input name="bot-field"></label></p>

        <input type="hidden" name="event_title" value="{{ event.data.title }}">
        <input type="hidden" name="event_date" value="{{ event.data.date_label }}">
        <input type="hidden" name="event_price" value="{{ event.data.price_num }}">

        <div class="form-row">
          <div class="form-field">
            <label for="ef-name">Ime in priimek <span class="req">*</span></label>
            <input type="text" id="ef-name" name="name" required autocomplete="name">
          </div>
          <div class="form-field">
            <label for="ef-people">Število oseb <span class="req">*</span></label>
            <input type="number" id="ef-people" name="people_count" required min="1" max="20" value="1">
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="ef-email">E-pošta <span class="req">*</span></label>
            <input type="email" id="ef-email" name="email" required autocomplete="email">
          </div>
          <div class="form-field">
            <label for="ef-phone">Telefon <span class="req">*</span></label>
            <input type="tel" id="ef-phone" name="phone" required autocomplete="tel" placeholder="041 234 567">
          </div>
        </div>

        <div class="form-field">
          <label for="ef-experience">Tvoje izkušnje s kolesarjenjem <span class="req">*</span></label>
          <select id="ef-experience" name="experience" required>
            <option value="">— izberi —</option>
            <option value="Začetnik/-ica">Začetnik/-ica (občasno vozim)</option>
            <option value="Srednje izkušen/-a">Srednje izkušen/-a (redno vozim, znam osnove)</option>
            <option value="Izkušen/-a">Izkušen/-a (vozim več let, tehnično dobro obvladam)</option>
            <option value="Napredni/-a">Napredni/-a (zahtevnejši tereni mi niso tuji)</option>
          </select>
        </div>

        <div class="form-field">
          <label for="ef-notes">Posebnosti, vprašanja, prehranske omejitve…</label>
          <textarea id="ef-notes" name="notes" rows="4" placeholder="Vse, kar bi morali vedeti."></textarea>
        </div>

        {% if event.data.payment_url %}
        <div class="form-field payment-method-field">
          <label>Način plačila <span class="req">*</span></label>
          <div class="payment-options">
            <label class="payment-option">
              <input type="radio" name="payment_method" value="Kartica (SumUp)" checked>
              <span class="payment-option-box">
                <span class="payment-option-title">Plačilo s kartico</span>
                <span class="payment-option-desc">Takojšnje plačilo prek SumUp</span>
              </span>
            </label>
            <label class="payment-option">
              <input type="radio" name="payment_method" value="Nakazilo preko TRR">
              <span class="payment-option-box">
                <span class="payment-option-title">Nakazilo preko TRR</span>
                <span class="payment-option-desc">Račun pošljemo na e-pošto</span>
              </span>
            </label>
          </div>
        </div>
        {% else %}
        <input type="hidden" name="payment_method" value="Nakazilo preko TRR">
        {% endif %}

        <button type="submit" class="btn btn-primary btn-lg btn-block btn-arrow" id="submitBtn">
          {% if event.data.payment_url %}Naprej na plačilo →{% else %}Pošlji prijavo →{% endif %}
        </button>

        <p class="event-form-fineprint" id="formFineprint">
          {% if event.data.payment_url %}
          Po oddaji prijave nadaljuješ glede na izbrani način plačila. Tvoji podatki pridejo do Galaxy Sport ekipe takoj.
          {% else %}
          Po oddaji prijave ti na e-pošto pošljemo račun v največ 24 urah.
          {% endif %}
        </p>
      </form>

      <!-- Success message shown after TRR submission -->
      <div class="form-success" id="formSuccess" hidden>
        <div class="form-success-mark">✓</div>
        <h3>Hvala za prijavo!</h3>
        <p>Račun ti bomo poslali na tvoj e-naslov v največ 24 urah.</p>
        <p class="form-success-sub">Če v tem času ne dobiš sporočila, preveri tudi mapo z neželeno pošto ali nas pokliči.</p>
      </div>
    </div>
  </div>
</section>

<section class="event-cta-section">
  <div class="container">
    <div class="event-cta-inner">
      <h2>Vprašanja pred prijavo?</h2>
      <p>Z veseljem odgovorimo na karkoli. Brez obvez.</p>
      <div class="event-cta-buttons">
        <a href="mailto:{{ event.data.contact_email or settings.contact_email }}?subject={{ ('Vprašanje o dogodku: ' + event.data.title) | urlencode }}" class="btn btn-outline btn-lg">Piši nam</a>
        <a href="tel:{{ settings.contact_phone_link }}" class="btn btn-outline btn-lg">Pokliči {{ settings.contact_phone }}</a>
      </div>
    </div>
  </div>
</section>

<footer id="contact">
  <div class="container">
    <div class="footer-top">
      <div>
        <a href="/" class="logo" aria-label="Galaxy Sport">
          <img src="/images/logo-light.png" alt="Galaxy Sport">
        </a>
        <p class="footer-tag">{{ settings.footer_tagline }}</p>
      </div>
      <div class="footer-col">
        <h4>Storitve</h4>
        <ul>
          <li><a href="/#services">Delavnice</a></li>
          <li><a href="/#services">Izleti</a></li>
          <li><a href="/#services">Počitnice</a></li>
          <li><a href="/#shop">Servis</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Galaxy Sport</h4>
        <ul>
          <li><a href="/#about">O nas</a></li>
          <li><a href="/#events">Dogodki</a></li>
          <li><a href="mailto:{{ settings.contact_email }}">Kontakt</a></li>
          <li><a href="/#faq">FAQ</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Sledi nam</h4>
        <ul>
          {% if settings.facebook_url %}<li><a href="{{ settings.facebook_url }}" target="_blank" rel="noopener">Facebook</a></li>{% endif %}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Galaxy Sport. Vse pravice pridržane.</span>
      <span>{{ settings.contact_email }} · {{ settings.contact_phone }}</span>
    </div>
  </div>
</footer>

<script>
// Smooth scroll from sidebar button to the form
const openBtn = document.getElementById('openFormBtn');
const formSection = document.getElementById('registrationForm');
if (openBtn && formSection) {
  openBtn.addEventListener('click', () => {
    formSection.classList.add('visible');
    formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => {
      const firstField = document.getElementById('ef-name');
      if (firstField) firstField.focus();
    }, 600);
  });
}

// Update submit button + fineprint text when payment method changes
const form = document.getElementById('eventForm');
const submitBtn = document.getElementById('submitBtn');
const fineprint = document.getElementById('formFineprint');
const paymentUrl = form ? form.dataset.paymentUrl : '';

function currentMethod() {
  const checked = form.querySelector('input[name="payment_method"]:checked');
  return checked ? checked.value : 'Nakazilo preko TRR';
}

function updateFormUI() {
  if (!paymentUrl) return; // no card option, leave defaults
  const method = currentMethod();
  if (method === 'Nakazilo preko TRR') {
    submitBtn.innerHTML = 'Pošlji prijavo →';
    if (fineprint) fineprint.textContent = 'Po oddaji prijave ti na e-pošto pošljemo račun v največ 24 urah.';
  } else {
    submitBtn.innerHTML = 'Naprej na plačilo →';
    if (fineprint) fineprint.textContent = 'Po oddaji prijave te preusmerimo na varno SumUp plačilno stran. Tvoji podatki pridejo do Galaxy Sport ekipe takoj.';
  }
}

if (form) {
  form.querySelectorAll('input[name="payment_method"]').forEach(r => {
    r.addEventListener('change', updateFormUI);
  });
  updateFormUI();

  form.addEventListener('submit', async (e) => {
    const method = currentMethod();

    // Bank transfer (TRR): submit to Netlify, then show the success message inline
    if (method === 'Nakazilo preko TRR') {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Pošiljam…';
      const params = new URLSearchParams();
      for (const [k, v] of new FormData(form)) params.append(k, v);
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        });
      } catch (err) { /* show success regardless */ }
      form.hidden = true;
      const success = document.getElementById('formSuccess');
      if (success) {
        success.hidden = false;
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    // Card (SumUp): submit to Netlify, then redirect to payment
    if (paymentUrl) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Pošiljam…';
      const params = new URLSearchParams();
      for (const [k, v] of new FormData(form)) params.append(k, v);
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        });
        window.location.href = paymentUrl;
      } catch (err) {
        window.location.href = paymentUrl;
      }
    }
    // If no paymentUrl and method is TRR, handled above. Nothing else needed.
  });
}

// ----- Event photo gallery lightbox -----
(function() {
  const items = document.querySelectorAll('.event-gallery-item[data-photo-index]');
  if (!items.length) return;
  const photos = Array.from(items).map(it => it.querySelector('img').src);

  const lb = document.createElement('div');
  lb.className = 'lightbox';
  lb.innerHTML = '<button class="lightbox-close" aria-label="Zapri">&times;</button>' +
    '<button class="lightbox-arrow lightbox-prev" aria-label="Prejšnja">&lsaquo;</button>' +
    '<button class="lightbox-arrow lightbox-next" aria-label="Naslednja">&rsaquo;</button>' +
    '<div class="lightbox-stage"><img class="lightbox-img" alt=""></div>' +
    '<div class="lightbox-counter"></div>';
  document.body.appendChild(lb);

  const img = lb.querySelector('.lightbox-img');
  const counter = lb.querySelector('.lightbox-counter');
  let idx = 0;

  function show(i) {
    idx = (i + photos.length) % photos.length;
    img.src = photos[idx];
    counter.textContent = (idx + 1) + ' / ' + photos.length;
  }
  function open(i) {
    show(i);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
    img.src = '';
  }

  items.forEach(it => it.addEventListener('click', () => open(parseInt(it.dataset.photoIndex, 10))));
  lb.querySelector('.lightbox-close').addEventListener('click', close);
  lb.querySelector('.lightbox-prev').addEventListener('click', () => show(idx - 1));
  lb.querySelector('.lightbox-next').addEventListener('click', () => show(idx + 1));
  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(idx - 1);
    if (e.key === 'ArrowRight') show(idx + 1);
  });
})();
</script>

</body>
</html>
